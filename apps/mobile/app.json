{
  "expo": {
    "name": "OmniValue AI",
    "slug": "omnivalue-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "omnivalue",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.omnivalue.app",
      "infoPlist": {
        "NSCameraUsageDescription": "OmniValue AI uses the camera to scan and identify items for your inventory.",
        "NSPhotoLibraryUsageDescription": "OmniValue AI accesses your photo library to add images of items to your inventory."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "ai.omnivalue.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "OmniValue AI accesses your photos to add images to your inventory.",
          "cameraPermission": "OmniValue AI uses the camera to scan items for your inventory."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
