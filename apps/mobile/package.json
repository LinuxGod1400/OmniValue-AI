{
  "name": "@omnivalue/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "OmniValue AI — React Native / Expo mobile app",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app/ components/ hooks/ lib/ constants/",
    "lint:fix": "eslint app/ components/ hooks/ lib/ constants/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf .expo node_modules/.cache"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@tanstack/react-query": "^5.64.1",
    "expo": "~52.0.28",
    "expo-haptics": "~13.0.1",
    "expo-image-picker": "~16.0.6",
    "expo-router": "~4.0.17",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.6",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.76.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
