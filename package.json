{
  "name": "omnivalue-ai",
  "version": "0.1.0",
  "private": true,
  "description": "OmniValue AI — AI-powered Android application monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' --filter './packages/*' dev",
    "dev:api": "pnpm --filter @omnivalue/api dev",
    "dev:mobile": "pnpm --filter @omnivalue/mobile dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "build:api": "pnpm --filter @omnivalue/api build",
    "build:mobile": "pnpm --filter @omnivalue/mobile build",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "test:coverage": "pnpm --recursive test:coverage",
    "clean": "pnpm --recursive clean && rimraf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-image-picker": "^57.0.1",
    "expo-secure-store": "^57.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "openai": "^6.45.0",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "uuid": "^14.0.1",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
